pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                bat 'npx playwright install'
            }
        }

        stage('Run UI Automation') {
            steps {
                bat 'npx playwright test UI_Automation/specs/orangehrm.spec.js --project=chromium'
            }
        }

        stage('Run Cucumber Tests') {
            steps {
                bat 'npx cucumber-js UI_Automation/features --require UI_Automation/step_definitions/*.js'
            }
        }

        stage('Run API Automation') {
            steps {
                bat 'npx playwright test API_Automation/restful.spec.js --project=chromium'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'test-results/**', allowEmptyArchive: true
        }
    }
}